---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { Button } from '@/components/ui/button';
import { Check } from 'lucide-react';
---

<Layout title="Pricing | Smart Cushion">
	<Navbar client:load />
	<main class="pt-32 pb-20">
		<section class="container mx-auto px-4 text-center">
			<h1 class="text-4xl lg:text-6xl font-bold mb-6">Simple, Transparent <span class="text-primary">Pricing</span></h1>
			<p class="text-xl text-muted-foreground mb-16 max-w-2xl mx-auto">
				Choose the plan that fits your lifestyle. All cushions come with a 2-year warranty and lifetime app access.
			</p>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
				{/* Standard Plan */}
				<div class="p-10 rounded-3xl bg-secondary/10 border text-left flex flex-col">
					<h3 class="text-2xl font-bold mb-2">Smart Cushion Solo</h3>
					<p class="text-muted-foreground mb-6">Perfect for home office setups.</p>
					<div class="text-4xl font-bold mb-8">$199 <span class="text-lg font-normal text-muted-foreground">/ one-time</span></div>
					<ul class="space-y-4 mb-10 flex-1">
						{['1x Smart Cushion', 'Mobile App Access', 'Cloud Backup', '2-Year Warranty'].map(item => (
							<li class="flex items-center gap-3">
								<Check class="w-5 h-5 text-primary" />
								<span>{item}</span>
							</li>
						))}
					</ul>
					<Button className="w-full h-12 rounded-full">Buy Now</Button>
				</div>

				{/* Pro Plan */}
				<div class="p-10 rounded-3xl bg-primary/10 border-2 border-primary text-left relative flex flex-col">
					<div class="absolute top-0 right-10 -translate-y-1/2 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase">Popular</div>
					<h3 class="text-2xl font-bold mb-2">Smart Cushion Bundle</h3>
					<p class="text-muted-foreground mb-6">For home and office use.</p>
					<div class="text-4xl font-bold mb-8">$349 <span class="text-lg font-normal text-muted-foreground">/ one-time</span></div>
					<ul class="space-y-4 mb-10 flex-1">
						{['2x Smart Cushion', 'Family App Sharing', 'Priority Support', 'Lifetime Warranty'].map(item => (
							<li class="flex items-center gap-3">
								<Check class="w-5 h-5 text-primary" />
								<span>{item}</span>
							</li>
						))}
					</ul>
					<Button className="w-full h-12 rounded-full">Buy Now</Button>
				</div>
			</div>
		</section>
	</main>
</Layout>
