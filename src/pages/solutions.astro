---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { SolutionsContent } from '../components/SolutionsContent';
import { SparklesCore } from '../components/ui/SparklesCore';
import { motion } from "framer-motion";
---

<Layout title="What We Solve | Smart Cushion">
	<Navbar client:load />
	<main class="bg-black">
    {/* High-Visibility Header with Sparkles and Glow */}
    <section class="relative h-[70vh] w-full flex flex-col items-center justify-center overflow-hidden bg-black">
      <div class="absolute inset-0 w-full h-full">
        <SparklesCore
          id="tsparticlesfullpage"
          background="transparent"
          minSize={0.6}
          maxSize={1.4}
          particleDensity={100}
          className="w-full h-full"
          particleColor="#FFFFFF"
          client:load
        />
      </div>
      
      {/* Central Glow Effect */}
      <div class="absolute inset-0 bg-gradient-to-b from-primary/20 via-transparent to-black pointer-events-none" />
      <div class="absolute w-[500px] h-[500px] bg-primary/10 blur-[120px] rounded-full pointer-events-none" />

      <div class="relative z-20 flex flex-col items-center px-4">
        <motion.h1
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.8 }}
          className="text-white text-5xl md:text-8xl font-bold text-center leading-tight mb-8"
        >
          The Hidden Cost <br/> <span class="text-primary drop-shadow-[0_0_15px_rgba(var(--primary),0.5)]">of Modern Work</span>
        </motion.h1>
        <motion.p
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ delay: 0.5, duration: 0.8 }}
          className="text-neutral-300 text-center max-w-2xl text-lg md:text-2xl font-medium"
        >
          Discover the silent impact of static sitting on your health, focus, and productivity.
        </motion.p>
      </div>

      <div class="absolute bottom-0 w-full h-40 bg-gradient-to-t from-black to-transparent z-10" />
    </section>

    {/* Storytelling Section */}
    <section class="py-24 bg-black relative z-20">
      <div class="container mx-auto px-4">
        <div class="mb-24 text-center">
          <h2 class="text-3xl lg:text-6xl font-bold text-white mb-8">A Journey through the <span class="text-primary">Problem</span></h2>
          <div class="w-32 h-1.5 bg-primary mx-auto rounded-full shadow-[0_0_10px_var(--primary)]" />
        </div>
        <SolutionsContent client:load />
      </div>
    </section>
    
    {/* Final Transition CTA */}
    <section class="py-32 bg-neutral-900/40 border-t border-neutral-800 relative z-20">
      <div class="container mx-auto px-4 text-center">
        <h3 class="text-2xl lg:text-4xl font-bold text-white mb-8 leading-relaxed">
          Understanding the problem is <br/> <span class="text-primary">the first step to recovery.</span>
        </h3>
        <a href="/features" class="inline-flex items-center gap-3 px-10 py-6 bg-primary text-white rounded-full font-bold text-xl hover:scale-105 transition-transform shadow-[0_0_40px_rgba(var(--primary),0.4)]">
          Explore the Solution
        </a>
      </div>
    </section>
	</main>
</Layout>
