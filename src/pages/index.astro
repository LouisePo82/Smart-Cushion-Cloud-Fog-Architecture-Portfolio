---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import { ProblemSection } from '../components/ProblemSection';
import { TechStack } from '../components/TechStack';
import { Spotlight } from '@/components/ui/Spotlight';
import { Button } from '@/components/ui/button';
import { ArrowRight } from 'lucide-react';
---

<Layout title="Smart Cushion | AI-Powered Ergonomic Seating">
	<Navbar client:load />
	
	<main class="relative overflow-hidden">
		<Spotlight className="-top-40 left-0 md:left-60 md:-top-20" fill="white" />
		<Hero client:load />
		
		<!-- Teaser Section -->
		<section class="py-24 bg-secondary/10">
			<div class="container mx-auto px-4 text-center">
				<h2 class="text-3xl lg:text-5xl font-bold mb-8">Engineering a <span class="text-primary">Painless</span> Future</h2>
				<p class="text-lg text-muted-foreground mb-12 max-w-2xl mx-auto">
					Our technology is more than just hardware. It's a comprehensive ecosystem designed to improve your health, one sit at a time.
				</p>
				<div class="flex justify-center gap-4">
					<a href="/features">
						<Button variant="outline" size="lg" class="rounded-full">
							Explore Features <ArrowRight class="ml-2 w-4 h-4" />
						</Button>
					</a>
				</div>
			</div>
		</section>
	</main>

	<footer class="py-12 border-t bg-black/50">
		<div class="container mx-auto px-4">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="flex items-center gap-2 font-bold text-xl">
					<div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white text-xs">S</div>
					<span>SmartCushion</span>
				</div>
				
				<div class="flex gap-8 text-sm font-medium text-muted-foreground">
					<a href="/features" class="hover:text-primary">Features</a>
					<a href="/app" class="hover:text-primary">App</a>
					<a href="/pricing" class="hover:text-primary">Pricing</a>
				</div>
				
				<p class="text-sm text-muted-foreground">
					© 2026 SmartCushion Inc.
				</p>
			</div>
		</div>
	</footer>
</Layout>
