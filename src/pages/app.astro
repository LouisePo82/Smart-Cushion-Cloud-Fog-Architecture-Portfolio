---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { Button } from '@/components/ui/button';
import { Monitor, Smartphone, LogIn, CheckCircle2, Globe } from 'lucide-react';
---

<Layout title="Mobile Setup | Smart Cushion">
	<Navbar client:load />
	<main class="pt-32 pb-20 overflow-hidden">
		<section class="container mx-auto px-4">
			<div class="flex flex-col lg:flex-row items-center gap-16">
				{/* Image Illustration */}
				<div class="flex-1 relative order-2 lg:order-1">
					<div class="relative z-10 rounded-[3rem] overflow-hidden border-4 border-white/10 shadow-2xl aspect-square max-w-lg mx-auto bg-neutral-900/40 p-4 backdrop-blur-sm">
						<div class="relative w-full h-full rounded-[2rem] overflow-hidden bg-black">
							<img src="/dashboard-1.png" alt="Dashboard on all devices" class="w-full h-full object-cover opacity-80" />
							<div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
							<div class="absolute bottom-10 left-0 w-full flex justify-center">
								<div class="flex gap-4">
									<Monitor className="text-primary w-8 h-8" />
									<div class="w-[1px] h-8 bg-white/20"></div>
									<Smartphone className="text-primary w-8 h-8" />
								</div>
							</div>
						</div>
					</div>
					<div class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[140%] h-[140%] bg-primary/10 blur-[120px] rounded-full"></div>
				</div>
				
				{/* Content Area */}
				<div class="flex-1 order-1 lg:order-2">
					<div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-bold uppercase tracking-wider mb-6">
						<Globe className="w-4 h-4" /> Web-Based Ecosystem
					</div>
					<h1 class="text-4xl lg:text-7xl font-bold mb-8 leading-tight tracking-tighter text-white">
						How to track your <br/><span class="text-primary italic">Wellbeing</span>
					</h1>
					<p class="text-xl text-neutral-400 mb-10 leading-relaxed max-w-xl">
						No app installation required. Our platform is built on modern web technologies, 
						allowing you to access your health data seamlessly across all your devices using any web browser.
					</p>

					<div class="space-y-6 mb-12">
						{[
							{ icon: Globe, t: "Step 1: Access Website", d: "Open your browser on PC or Mobile and visit our platform." },
							{ icon: LogIn, t: "Step 2: Login", d: "Enter your university or project credentials to sync your data." },
							{ icon: CheckCircle2, t: "Step 3: Real-time Sync", d: "Your Smart Cushion data will automatically stream to your dashboard." }
						].map(item => (
							<div class="flex items-start gap-6 p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-primary/50 transition-all group">
								<div class="p-3 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors">
									<item.icon className="w-6 h-6" />
								</div>
								<div>
									<h3 class="text-xl font-bold text-white mb-1">{item.t}</h3>
									<p class="text-neutral-400 leading-relaxed">{item.d}</p>
								</div>
							</div>
						))}
					</div>

					<div class="flex flex-wrap gap-6">
						<a href="/dashboard">
							<Button size="lg" class="rounded-full px-10 h-16 text-lg font-bold shadow-xl shadow-primary/20">
								Open Dashboard
							</Button>
						</a>
						<Button size="lg" variant="outline" class="rounded-full px-10 h-16 text-lg font-bold border-white/20">
							Learn More
						</Button>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		background: radial-gradient(circle at top right, rgba(var(--primary-rgb), 0.05), transparent 40%),
					radial-gradient(circle at bottom left, rgba(var(--primary-rgb), 0.05), transparent 40%);
	}
</style>
